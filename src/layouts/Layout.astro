---
import RootLayout from './RootLayout.astro';
import PageLayout from './PageLayout.astro';
import type { SEOProps } from './layout-props';

const { title, description, titleSuffix }: SEOProps = Astro.props;
---

<RootLayout title={title} description={description} titleSuffix={titleSuffix}>
  <PageLayout>
    <slot />
  </PageLayout>
</RootLayout>
