---
import RootLayout from './RootLayout.astro';
import PageLayout from './PageLayout.astro';
import type { SEOProps } from './layout-props';

const {
  title,
  description,
  titleSuffix,
  canonical,
  ogImage,
  type,
  tags,
  publishedTime,
  modifiedTime,
  noindex,
  jsonLd,
}: SEOProps = Astro.props;
---

<RootLayout
  canonical={canonical}
  description={description}
  jsonLd={jsonLd}
  modifiedTime={modifiedTime}
  noindex={noindex}
  ogImage={ogImage}
  publishedTime={publishedTime}
  tags={tags}
  title={title}
  titleSuffix={titleSuffix}
  type={type}
>
  <PageLayout>
    <slot />
  </PageLayout>
</RootLayout>
