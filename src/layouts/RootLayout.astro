---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import type { SEOImage, SEOProps } from './layout-props';

const {
  title = '',
  description = 'Creative engineer shaping meaningful products through technical depth and strong vision.',
  titleSuffix = 'Tom Radford',
  canonical,
  ogImage,
  type = 'website',
  tags = [],
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
}: SEOProps = Astro.props;

const finalTitle = title
  ? title.includes(' | ')
    ? title
    : `${title} | ${titleSuffix}`
  : titleSuffix;

const canonicalUrl = Astro.site ? new URL(canonical ?? Astro.url.pathname, Astro.site) : undefined;
const ogImageData: SEOImage | undefined =
  typeof ogImage === 'string' ? { src: ogImage } : ogImage;
const ogImageUrl =
  ogImageData?.src && Astro.site ? new URL(ogImageData.src, Astro.site).toString() : undefined;
const robotsContent = noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large';
const jsonLdPayload = jsonLd ? JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : undefined;
---

<html class="h-full" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="author" content={titleSuffix} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl.toString()} />}
    {Astro.site && <link rel="sitemap" href={new URL('/sitemap-index.xml', Astro.site).toString()} />}
    {
      Astro.site && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={`${titleSuffix} RSS Feed`}
          href={new URL('/rss.xml', Astro.site).toString()}
        />
      )
    }
    <meta name="generator" content={Astro.generator} />
    <meta property="og:site_name" content={titleSuffix} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl.toString()} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:secure_url" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content={String(ogImageData?.width ?? 1200)} />}
    {ogImageUrl && <meta property="og:image:height" content={String(ogImageData?.height ?? 630)} />}
    {ogImageData?.alt && <meta property="og:image:alt" content={ogImageData.alt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageData?.alt && <meta name="twitter:image:alt" content={ogImageData.alt} />}
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {
      type === 'article' &&
        tags.map((tag) => <meta property="article:tag" content={tag} />)
    }
    {jsonLdPayload && (
      <script is:inline type="application/ld+json" set:html={jsonLdPayload}></script>
    )}
    <title>{finalTitle}</title>
    <script is:inline>
      (() => {
        try {
          const storageKey = 'theme-preference';
          const storedTheme = localStorage.getItem(storageKey);
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const shouldUseDark = storedTheme ? storedTheme === 'dark' : prefersDark;
          document.documentElement.classList.toggle('dark', shouldUseDark);
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-full bg-background text-foreground">
    <slot />
  </body>
</html>
