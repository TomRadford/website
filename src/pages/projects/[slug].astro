---
import { getCollection, render } from 'astro:content';
import ContentPageHeader from '../../components/content/ContentPageHeader.astro';
import ProseImage from '../../components/content/ProseImage.astro';
import ProseLink from '../../components/content/ProseLink.astro';
import Prose from '../../components/Prose.astro';
import RootLayout from '../../layouts/RootLayout.astro';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<RootLayout description={project.data.description} title={project.data.title}>
  <PageLayout>
    <article class="mx-auto flex w-full max-w-3xl flex-col gap-2 md:gap-4">
      <ContentPageHeader
        description={project.data.description}
        entity="Project"
        links={project.data.links}
        tags={project.data.tags}
        title={project.data.title}
      />
      <Prose>
        <Content components={{ a: ProseLink, img: ProseImage }} />
      </Prose>
    </article>
  </PageLayout>
</RootLayout>
