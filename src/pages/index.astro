---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import MomentCard from '../components/home/MomentCard.astro';
import Carousel from '../components/bearnie/carousel/Carousel.astro';
import CarouselContent from '../components/bearnie/carousel/CarouselContent.astro';
import CarouselItem from '../components/bearnie/carousel/CarouselItem.astro';
import CarouselNext from '../components/bearnie/carousel/CarouselNext.astro';
import CarouselPrevious from '../components/bearnie/carousel/CarouselPrevious.astro';
import RootLayout from '../layouts/RootLayout.astro';
import PageLayout from '../layouts/PageLayout.astro';
import Link from '../components/ui/Link.astro';

import heroPortrait from '../assets/hero-portrait.png';

const moments = await getCollection('moments');
const projects = (await getCollection('projects')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
const skills = [
  'Web dev',
  'Runner',
  'React user',
  'Mountain explorer',
  'Javascript fiend',
  'Wave-rider',
  'Mentor',
  'Folktronica & house lover',
  'Cloudflarer',
  'Mentee',
  'Camera-person',
  'DnB enjoyer',
  'Hype-man',
];
---

<RootLayout
  description="Creative engineer shaping meaningful products through technical depth and strong vision."
  title="Creative Engineer"
>
  <PageLayout>
    <section class="grid gap-8 md:grid-cols-5 md:gap-14" id="about">
      <div class="flex flex-col gap-5 md:gap-6 md:col-span-3">
        <h1 class="text-3xl leading-tight font-semibold text-foreground md:text-5xl">
          Creative engineer shaping meaningful products through technical depth and strong vision.
        </h1>
        <p class="text-sm leading-normal text-body-copy md:text-lg">
          As a problem-orientated technologist, I thrive at the intersection between art, humans and
          engineering. I am always pushing the limits of my ability to develop unique works and
          useful solutions while maintaining a passion for collaboration and ingenuity.
        </p>
        <p class="font-mono text-xs leading-relaxed text-muted-foreground md:text-sm">
          {
            skills.map((skill, index) => (
              <>
                {index > 0 && ' · '}
                {skill}
              </>
            ))
          }
        </p>
        <div class="flex gap-5">
          <Link href="/projects"> Projects → </Link>
          <Link href="/writing" variant="accent"> Writing → </Link>
        </div>
      </div>

      <div class="flex flex-col gap-3 md:max-w-md md:justify-self-end md:col-span-2 md:my-auto">
        <Image
          alt="Tom Radford portrait"
          class="h-96 w-full rounded-2xl object-cover md:h-96"
          src={heroPortrait}
          loading="eager"
        />
        <p class="text-center text-xs text-muted-foreground">Me, stoked on building cool shit.</p>
      </div>
    </section>

    <section class="space-y-3" id="projects">
      <h2 class="text-xl font-semibold text-foreground md:text-2xl">Sick projects</h2>
      {
        projects.slice(0, 3).map((project) => (
          <p>
            <a
              class="text-sm leading-snug text-body-copy transition-colors hover:text-accent md:text-lg md:leading-snug"
              href={`/projects/${project.id}`}
            >
              {project.data.tagline} →
            </a>
          </p>
        ))
      }
    </section>

    <section class="space-y-3" id="writing">
      <h2 class="text-xl font-semibold text-foreground md:text-2xl">Latest writing</h2>
      <p>
        <a
          class="text-sm leading-snug text-body-copy transition-colors hover:text-accent md:text-lg md:leading-snug"
          href="#"
        >
          building a web-component with vue →
        </a>
      </p>
      <p>
        <a
          class="text-sm leading-snug text-body-copy transition-colors hover:text-accent md:text-lg md:leading-snug"
          href="#"
        >
          planning your next idea with exalidraw →
        </a>
      </p>
      <p>
        <a
          class="text-sm leading-snug text-body-copy transition-colors hover:text-accent md:text-lg md:leading-snug"
          href="#"
        >
          How I track trains in Cape Town →
        </a>
      </p>
    </section>

    <section class="space-y-3 mb-8" id="moments">
      <h2 class="text-lg font-semibold text-foreground md:text-2xl">Me in action</h2>
      <div class="relative">
        <Carousel class="overflow-visible" slidesPerView="auto" spacing={14} autoplay={false}>
          <CarouselPrevious />
          <CarouselNext />
          <CarouselContent>
            {
              moments.map((moment) => (
                <CarouselItem class="w-72 flex-none max-md:w-60">
                  <MomentCard caption={moment.data.caption} src={moment.data.image} />
                </CarouselItem>
              ))
            }
          </CarouselContent>
        </Carousel>
      </div>
    </section>
  </PageLayout>
</RootLayout>
