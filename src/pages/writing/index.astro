---
import { getCollection } from 'astro:content';
import ListPage from '../../components/content/ListPage.astro';
import RootLayout from '../../layouts/RootLayout.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { WRITING_INDEX_OG_IMAGE } from '../../utils/open-graph';

const writing = (await getCollection('writing')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const items = writing.map((post) => ({
  href: `/${post.id}`,
  title: post.data.title,
  excerpt: post.data.description,
  tags: post.data.tags,
  publishedAt: post.data.publishedAt,
}));
---

<RootLayout
  description="Writing on building products, systems, and useful software."
  ogImage={WRITING_INDEX_OG_IMAGE}
  title="Writing"
>
  <PageLayout>
    <ListPage
      entityType="writing"
      items={items}
      subtitle="various ramblings listed below"
      title="my thoughts."
    />
  </PageLayout>
</RootLayout>
