---
import { getCollection, render } from 'astro:content';
import ContentPageHeader from '../components/content/ContentPageHeader.astro';
import ProseImage from '../components/content/ProseImage.astro';
import ProseLink from '../components/content/ProseLink.astro';
import Prose from '../components/Prose.astro';
import RootLayout from '../layouts/RootLayout.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { getWritingOgImagePath } from '../utils/open-graph';

export async function getStaticPaths() {
  const writing = await getCollection('writing');

  return writing.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const ogImage = getWritingOgImagePath(post.id);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Tom Radford',
    url: 'https://theradford.com',
  },
  image: [new URL(ogImage, Astro.site ?? Astro.url).toString()],
  keywords: post.data.tags,
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString(),
};
---

<RootLayout
  description={post.data.description}
  jsonLd={articleSchema}
  ogImage={ogImage}
  publishedTime={post.data.publishedAt.toISOString()}
  tags={post.data.tags}
  title={post.data.title}
  type="article"
>
  <PageLayout>
    <article class="mx-auto flex w-full max-w-3xl flex-col gap-2 md:gap-4">
      <ContentPageHeader
        description={post.data.description}
        entity="Writing"
        links={post.data.links}
        publishedAt={post.data.publishedAt}
        tags={post.data.tags}
        title={post.data.title}
      />
      <Prose>
        <Content components={{ a: ProseLink, img: ProseImage }} />
      </Prose>
    </article>
  </PageLayout>
</RootLayout>
