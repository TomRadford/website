---
import type { ImageMetadata } from 'astro';
import type { HTMLAttributes } from 'astro/types';
import { Image } from 'astro:assets';

interface Props extends Omit<HTMLAttributes<'img'>, 'src'> {
  src: string | ImageMetadata;
  alt?: string;
  title?: string;
}

const { src, alt = '', title, width, height, ...attrs } = Astro.props;
const caption = title || alt;
const isHtmlImage = typeof src === 'string';
---

<figure class="not-prose my-8 flex flex-col gap-3">
  {
    isHtmlImage ? (
      <img
        alt={alt}
        class="w-full rounded-2xl object-cover"
        height={height}
        loading="lazy"
        src={src}
        width={width}
        {...attrs}
      />
    ) : (
      <Image
        alt={alt}
        class="w-full rounded-2xl object-cover"
        loading="lazy"
        src={src}
        {...attrs}
      />
    )
  }

  {
    caption && (
      <figcaption class="text-sm leading-relaxed text-muted-foreground">{caption}</figcaption>
    )
  }
</figure>
