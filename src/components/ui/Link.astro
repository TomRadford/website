---
import type { HTMLAttributes } from 'astro/types';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '../../utils/cn';

const linkVariants = cva('text-sm font-medium md:text-base', {
  variants: {
    variant: {
      default: 'text-body-copy transition-colors hover:text-accent',
      accent: 'text-accent transition-opacity hover:opacity-80',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
});

export interface Props extends HTMLAttributes<'a'>, VariantProps<typeof linkVariants> {}

const { class: className, variant = 'default', ...props } = Astro.props;
const classes = cn(linkVariants({ variant }), className);
---

<a class={classes} {...props}>
  <slot />
</a>
