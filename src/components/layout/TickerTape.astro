---
import TickerRow from './TickerRow.astro';

const labels = [
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
];
---

<section aria-label="Site ticker tape" class="overflow-hidden border-y-[3px]">
  <div class="flex w-max animate-ticker-scroll motion-reduce:animate-none">
    <TickerRow labels={labels} />
    <div aria-hidden="true">
      <TickerRow labels={labels} />
    </div>
  </div>
</section>
