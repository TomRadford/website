---
const labels = [
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
  'Tom Radford',
]
---

<section aria-label="Site ticker tape" class="ticker-shell">
  <div class="ticker-track">
    <div class="ticker-group">
      {labels.map((label) => (
        <span class="text-2xl whitespace-nowrap text-center font-black leading-none text-brand-text md:text-3xl">
          {label}
        </span>
      ))}
    </div>
    <div aria-hidden="true" class="ticker-group">
      {labels.map((label) => (
        <span class="text-2xl whitespace-nowrap text-center font-black leading-none text-brand-text md:text-3xl">
          {label}
        </span>
      ))}
    </div>
  </div>
</section>
