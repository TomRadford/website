---
import Logo from './Logo.astro';
import Menu from '@lucide/astro/icons/menu';

const navItems = [
  { href: '/', label: 'About' },
  { href: '/writing', label: 'Writing' },
  { href: '/projects', label: 'Projects' },
];
---

<header class="w-full" id="top">
  <nav class="flex items-center justify-between pb-3">
    <Logo />

    <div class="hidden items-center gap-6 text-sm text-brand-text md:flex">
      {
        navItems.map(({ href, label }) => (
          <a class="transition-colors hover:text-accent" href={href}>
            {label}
          </a>
        ))
      }
      <button
        aria-label="Toggle dark mode"
        class="cursor-pointer transition-colors hover:text-accent"
        data-theme-toggle
        type="button"
      >
        Dark / Light
      </button>
    </div>

    <button
      aria-controls="mobile-nav-panel"
      aria-expanded="false"
      aria-label="Toggle menu"
      class="cursor-pointer text-brand-text transition-colors hover:text-accent md:hidden"
      data-mobile-menu-trigger
      type="button"
    >
      <Menu aria-hidden="true" size={20} stroke-width={2} />
    </button>
  </nav>

  <div class="hidden border-y border-border py-3 md:hidden" id="mobile-nav-panel">
    <div class="flex flex-col gap-3">
      {
        navItems.map(({ href, label }) => (
          <a
            class="text-lg font-medium text-foreground transition-colors hover:text-accent"
            href={href}
          >
            {label}
          </a>
        ))
      }
      <div class="h-px w-full bg-border"></div>
      <button
        aria-label="Toggle dark mode"
        class="w-fit cursor-pointer text-sm text-muted-foreground transition-colors hover:text-accent"
        data-theme-toggle
        type="button"
      >
        Dark / Light
      </button>
    </div>
  </div>
</header>

<script>
  const trigger = document.querySelector('[data-mobile-menu-trigger]');
  const panel = document.querySelector('#mobile-nav-panel');

  if (trigger instanceof HTMLButtonElement && panel instanceof HTMLDivElement) {
    const closeMenu = () => {
      panel.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    };

    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      panel.classList.toggle('hidden', expanded);
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
