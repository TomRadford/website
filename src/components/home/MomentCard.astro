---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  caption: string;
  src: ImageMetadata;
}

const { caption, src }: Props = Astro.props;
---

<article class="w-72 flex-none max-md:w-60 max-md:snap-start">
  <Image
    alt={caption || 'Cool image of Tom!'}
    class="h-56 w-full rounded-xl object-cover max-md:h-44"
    loading="eager"
    src={src}
  />
  {caption && <p class="mt-2 text-xs text-muted-foreground">{caption}</p>}
</article>
