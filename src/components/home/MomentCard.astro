---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  alt: string
  caption: string
  decorative?: boolean
  src: ImageMetadata
}

const { alt, caption, decorative = false, src }: Props = Astro.props
---

<article class="w-72 flex-none max-md:w-60 max-md:snap-start">
  <Image
    alt={decorative ? '' : alt}
    class="h-56 w-full rounded-xl object-cover max-md:h-44"
    loading="lazy"
    src={src}
  />
  <p class="mt-2 text-xs text-muted-foreground">{caption}</p>
</article>
