---
import type { CollectionEntry } from 'astro:content';
import Link from '../ui/Link.astro';
import { ExternalLinkIcon } from '@lucide/astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project }: Props = Astro.props;
---

<header class="flex flex-col gap-5">
  <div class="flex flex-col gap-3">
    <p class="text-xs font-medium tracking-[0.16em] text-muted-foreground uppercase">Project</p>
    <h1 class="text-3xl leading-tight font-semibold text-foreground md:text-5xl">
      {project.data.title}
    </h1>
    <p class="max-w-2xl text-sm leading-relaxed text-body-copy md:text-lg">
      {project.data.description}
    </p>
  </div>

  {
    project.data.tags.length > 0 && (
      <p class="font-mono text-xs leading-relaxed text-muted-foreground md:text-sm">
        {project.data.tags.join(' · ')}
      </p>
    )
  }

  {
    project.data.links.length > 0 && (
      <div class="flex flex-wrap gap-x-5 gap-y-3 pt-1">
        {project.data.links.map((link) => (
          <Link variant="accent" href={link.link} rel="noreferrer" target="_blank">
            {link.title}
            <ExternalLinkIcon size={14} stroke-width={2} />
          </Link>
        ))}
      </div>
    )
  }
</header>
